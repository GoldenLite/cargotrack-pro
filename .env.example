# CargoTrack Pro — пример переменных окружения.
# Скопируйте в .env и заполните для вашего окружения.
# .env НЕ коммитится в репозиторий.

# ── Среда ────────────────────────────────────────────────────────────────────
DJANGO_ENV=dev                       # dev | prod

# ── Django core ──────────────────────────────────────────────────────────────
# В prod — ОБЯЗАТЕЛЬНО (минимум 50 случайных символов).
# Сгенерировать: python -c "import secrets;print(secrets.token_urlsafe(60))"
DJANGO_SECRET_KEY=

# Если пусто — DEBUG = True в dev / False в prod.
DJANGO_DEBUG=

# CSV. Для dev по умолчанию ['*']; для prod ОБЯЗАТЕЛЬНО.
DJANGO_ALLOWED_HOSTS=

# ── Безопасность (актуально только для prod) ─────────────────────────────────
# CSV доменов с https://, для CSRF.
DJANGO_CSRF_TRUSTED_ORIGINS=

# CSV. Если пусто в prod — CORS запрещён (CORS_ALLOW_ALL_ORIGINS=False).
DJANGO_CORS_ALLOWED_ORIGINS=

# 1 = включить редирект http→https. По умолчанию 1 в prod.
DJANGO_SECURE_SSL_REDIRECT=

# 1 = включить SECURE_PROXY_SSL_HEADER (если стоит за nginx/балансером).
DJANGO_SECURE_PROXY_SSL_HEADER=

# Время HSTS в секундах. На старте 0; после уверенности — 3600, 86400, 31536000.
DJANGO_HSTS_SECONDS=

# ── Email (для prod, если рассылаются уведомления) ──────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=CargoTrack Pro <noreply@example.com>

# ── Management commands ──────────────────────────────────────────────────────
# Пароль для testuser, создаваемого load_hawb_data. Если пусто — генерится
# случайный и печатается в stdout.
CARGO_TESTUSER_PASSWORD=

# ── Альта-ГТД / ФТС интеграция ────────────────────────────────────────────────
# Реквизиты, которые попадают в каждый ЭД-документ.

# Идентификатор участника ВЭД — ОГРН (13 цифр) или ИНН (10/12 цифр) вашей
# компании. Используется в <edh:ParticipantID>. Без него ФТС документ не примет.
ALTA_PARTICIPANT_ID=

# 8-значный код таможни-получателя по классификатору ФТС.
# Примеры: 10005030 (Внуковская т/п), 10009030 (Шереметьевская т/п).
# Узнайте у вашего таможенного брокера или из спецификации поста подачи.
ALTA_CUSTOMS_CODE=

# Реквизиты таможенного представителя (та организация, что подаёт декларацию
# от вашего имени — обычно ваша же компания, либо CDEK / иной брокер).
ALTA_CARRIER_NAME=
ALTA_CARRIER_CERT=            # рег. № в реестре таможенных представителей, формат: "NNNN/NN"
ALTA_CARRIER_INN=             # ИНН представителя (10 или 12 цифр)
ALTA_CARRIER_OKPO=            # ОКПО представителя (необязательно)
ALTA_CARRIER_CITY=
ALTA_CARRIER_STREET=

# Путь к hot-folder Альта-ГТД (папке, которую слушает ЭД-Сервис).
# Используется ТОЛЬКО если Django крутится на той же машине, что и Альта.
# Если у тебя Django на VPS, а Альта на отдельном ПК — оставь пустым,
# документы будут уходить через очередь + agent (см. ALTA_AGENT_TOKEN ниже).
ALTA_HOTFOLDER_PATH=

# Токен авторизации для alta-агента (скрипт, который забирает документы
# из очереди и кладёт в hot-folder локальной Альты). Поставь любой длинный
# случайный токен. Тот же токен пропиши в alta_agent/alta_agent.ini на
# машине, где запускается агент.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
ALTA_AGENT_TOKEN=

# Путь к JSON-credentials Google Service Account (для импорта таблиц).
# Если переменная пустая или файл отсутствует — фича Sheets-импорта
# отключена (сервис продолжает работать). Service Account должен иметь
# scope `spreadsheets.readonly` и быть расшарен в обоих spreadsheet'ах.
# Пример: C:\cargotrack\secrets\google_service_account.json
GOOGLE_SA_CREDENTIALS_FILE=

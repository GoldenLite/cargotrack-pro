[agent]
# URL твоего сервиса CargoTrack Pro (без хвостового слеша или с ним — неважно)
base_url = https://cargotrack.example.com

# Тот же токен, что задан в .env Django как ALTA_AGENT_TOKEN.
# Сгенерируй любой длинный случайный (например, `python -c "import secrets; print(secrets.token_urlsafe(48))"`).
token = ЗАМЕНИ_МЕНЯ

# Папка, которую Альта мониторит как «Автозагрузка»
# (Альта-ГТД → Настройка → Внешние программы → Загрузка → Путь к папке)
hotfolder = C:\ALTA\inbox

# Как часто опрашивать API (сек)
poll_interval_seconds = 4

# Сколько ждать после сетевой ошибки перед повтором (сек)
error_retry_seconds = 30


# ── Inbox: чтение входящих ЭД от таможни ──────────────────────────────
# Параллельный поток в том же pythonw-процессе. Читает .gz из watch_dir,
# отправляет в /api/v1/alta/inbox/. Файлы НЕ удаляет (это работа
# существующего s3_upload_files_ek5.py — он удаляет после своего POST).
# Если секцию закомментировать целиком — inbox-поток отключён.

[inbox]
# Где Альта складывает входящие ЭД-сообщения от таможни
watch_dir = C:\GTDSERV\ED\IN

# Отдельный токен от ALTA_AGENT_TOKEN. На VPS должен быть задан как
# ALTA_INBOX_TOKEN в .env. Сгенерь длинный random:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
token = ЗАМЕНИ_МЕНЯ_ДРУГОЙ_ТОКЕН

# Как часто сканить папку (сек). watchdog не использован сознательно —
# polling проще и меньше зависимостей.
poll_interval = 5

# Локальная sqlite-база с EnvelopeID уже обработанных файлов.
# Защищает от повторной отправки если файл ещё не удалён s3-скриптом.
state_db = inbox_state.sqlite

# Endpoint на VPS. Менять обычно не нужно.
endpoint = /api/v1/alta/inbox/

# Regex по имени файла — какие .gz обрабатывать.
# Альта складывает и outgoing-копии (`538134^*.gz`), и incoming
# (`serveralta^*.gz`). По умолчанию берём только incoming.
name_pattern = ^serveralta\^

# Архив: куда копируем каждый .gz ДО парсинга. На рабочем сервере параллельно
# работает s3_upload_files_ek5.py, который УДАЛЯЕТ файлы из watch_dir после
# своей обработки. Если он опередит нас — файл пропадёт. Архив = наша
# гарантированная копия. По умолчанию <script_dir>/inbox_archive.
# В норме файлы удаляются сразу после успешной отправки на VPS (raw_xml уже
# в БД на VPS, держать вторую копию незачем).
# archive_dir = C:\ALTA\IN\alta_agent\inbox_archive

# Safety-net: сколько дней хранить файлы которые НЕ удалось залить на VPS
# (постоянно failed POST). 0 = не удалять застрявшие никогда.
archive_keep_days = 7


# ── Outbox: наблюдение за исходящими копиями Альты ────────────────────
# Альта сама генерирует EnvelopeID для своих исходящих пакетов (отправки
# документов в таможню), мы не знаем эти UUID. Чтобы потом матчить
# входящие ответы (CMN.00003, CMN.11337 и т.д.) к нашим Cargo/HAWB,
# нужно наблюдать исходящие копии и сохранять пары (EnvelopeID, MAWB/HAWB).
# Файлы НЕ удаляем — только читаем.
# Если секцию закомментировать целиком — outbox-поток отключён.

[outbox]
# По умолчанию использует watch_dir и token из [inbox]. Можно переопределить.
# watch_dir = C:\GTDSERV\ED\IN
# token     = (по умолчанию = inbox.token)

# Как часто сканить (сек).
poll_interval = 5

# Локальная sqlite-база уже отправленных EnvelopeID (отдельная от inbox).
state_db = outbox_state.sqlite

# Endpoint на VPS.
endpoint = /api/v1/alta/outbox/

# Regex по имени файла — Альтa-исходящие имеют префикс с цифровым ID
# (видимо ID участника ВЭД). Может различаться у разных установок.
name_pattern = ^538134\^


# ── SVH Outbox: наблюдение за исходящими ЭД от ed2svh.exe (СВХ-Альты) ──
# ed2svh.exe копирует исходящие сообщения в backup_out при включённом
# чекбоксе «Резервная копия» в его GUI-настройках (Подключение ЭД).
# Внутри лежат plain XML (do1-*.xml = ДО-1 отчёт о размещении на СВХ,
# ca-*.xml = коммерческий акт о расхождении). Парсим только do1-*.xml,
# ca-*.xml пропускаем.
# Mtime файла = момент когда ed2svh отправил документ в таможню =
# точная «дата подачи ДО1» которую пишем в Sheets.
# Файлы НЕ удаляем (Альта-СВХ их не чистит, лежат архивом).
# Если секцию закомментировать целиком — поток отключён.

[svh_outbox]
# Папка backup_out из настроек ed2svh.exe
watch_dir = C:\ALTA\SvhPro\ED2SVH\backup_out

# Тот же токен что у [inbox] (один и тот же ALTA_INBOX_TOKEN)
# token = (по умолчанию = inbox.token)

# Polling каждые 30 сек — файлы не удаляются, спешить некуда.
poll_interval = 30

# Локальная sqlite-база (отдельная от inbox/outbox).
state_db = svh_outbox_state.sqlite

# Endpoint на VPS. Тот же что у [outbox] (msg_type='ED.DO1' разводит логику).
endpoint = /api/v1/alta/outbox/


# ── DB Reconcile: сверка с БД Альты (Postgres) ─────────────────────────
# Опрашивает Postgres БД Альты-ГТД на предмет входящих сообщений за окно
# (window_days), узнаёт у VPS какие envelope_id у нас отсутствуют, и
# докачивает их тела из `edmsgsxml` → отправляет на /api/v1/alta/inbox/.
# Закрывает дырки, образовавшиеся когда inbox-watcher не сработал (агент
# был выключен, s3-скрипт опередил, ошибки архива и т.п.).
#
# По умолчанию ВЫКЛЮЧЕНО — на машинах без psycopg2 / без доступа к PG.
# Включить: enabled=true + установить psycopg2-binary (uv add psycopg2-binary
# или pip install psycopg2-binary).
#
# Безопасность: read-only сессия, statement_timeout=60s.

[db_reconcile]
enabled = false

# Период опроса (сек). 600 = раз в 10 минут.
poll_interval = 600

# Окно сверки: смотрим сообщения за последние N дней.
window_days = 2

# Чанк для batch-запроса /api/v1/alta/inbox/missing/.
chunk = 2000

# Реквизиты БД Альты-ГТД (Postgres).
db_host = 10.129.0.9
db_port = 5432
db_name = alta
db_user = alta_admin
db_password =

# Фильтр типов сообщений, которые сверяем. Через запятую без пробелов.
# Сюда добавлены входящие, которые реально парсятся на VPS.
msg_types = CMN.11337,CMN.11314,CMN.11350,MY.11003,ED.11003,ED.11010,CMN.11010,CMN.11001,CMN.11002,CMN.11309,CMN.11310,ED.11002
